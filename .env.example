# =============================================
# OMNICHANNEL-BOT - Environment Variables
# Copy this file to .env and fill in the values
# =============================================

# Server
PORT=3000
NODE_ENV=development

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Facebook / Meta (Platform-level)
FB_VERIFY_TOKEN=your_facebook_verify_token_here
FB_APP_ID=your_facebook_app_id_here
FB_APP_SECRET=your_facebook_app_secret_here
# FB_PAGE_ACCESS_TOKEN đã chuyển sang lưu trong DB theo từng Shop (qua OAuth)

# Zalo OA (Phase 2)
# ZALO_OA_SECRET=your_zalo_oa_secret_here
# ZALO_OA_ACCESS_TOKEN=your_zalo_oa_access_token_here

# Gemini AI (Agent B)
GEMINI_API_KEY=your_gemini_api_key_here
